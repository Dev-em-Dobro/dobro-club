# --- Server ---
# Strong random secret for signing session cookies. REQUIRED in production
# (the server refuses to boot in production without it). Generate e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
DOBRO_SESSION_SECRET=
# Public base URL used to BUILD magic links — must match where the app is reachable
# (otherwise links ship as http://localhost:3001/...).
DOBRO_BASE_URL=http://localhost:3001
# Set to "production" to enable Secure cookies and the session-secret boot guard.
NODE_ENV=
# Trusted proxy hops for correct client IP in rate limiting. 0 = no proxy.
TRUST_PROXY_HOPS=0
# Port the API/server listens on.
PORT=3001

# --- Frontend (Vite) ---
# WhatsApp support/contact link used by the "pedir novo link" CTA. Set the real number at deploy.
VITE_SUPPORT_WA_URL=https://wa.me/5511999999999
