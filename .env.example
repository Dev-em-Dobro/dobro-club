# Copie para `.env` (gitignored) e preencha. NUNCA coloque valores reais aqui.

# --- Server ---
# Segredo forte p/ assinar cookies de sessão. OBRIGATÓRIO em produção
# (o servidor recusa boot sem ele). Gere: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
DOBRO_SESSION_SECRET=
# URL pública usada para MONTAR os magic links (precisa bater com onde o app responde).
DOBRO_BASE_URL=http://localhost:3001
# "production" liga cookies Secure e o guard do segredo de sessão.
NODE_ENV=
# Hops de proxy confiáveis (IP correto no rate limit). 0 = sem proxy.
TRUST_PROXY_HOPS=0
PORT=3001

# --- Neon Postgres ---
# Connection string do painel da Neon (use o endpoint pooled "-pooler").
DATABASE_URL=
# Conexão direta (não-pooled), p/ migrations. Opcional.
DIRECT_URL=
# Neon root CA PEM; set to enforce TLS verification in prod (NEON_CA_CERT=<pem-contents>).
NEON_CA_CERT=

# --- Resend (entrega do magic link por e-mail) ---
# API key em resend.com.
RESEND_API_KEY=
# Remetente. PRECISA ser um e-mail de domínio verificado (ou onboarding@resend.dev p/ teste).
# Formato: "Nome <email@dominio>".
EMAIL_FROM=

# --- ActiveCampaign (onboarding 8.15 — grava o magic link no contato) ---
# Só necessário em eventos cujo onboarding é enviado pela AC. Sem as 3 vars, a
# gravação do link vira no-op (best-effort). Passo a passo da config no AC:
# Guia completo: specs/TUTORIAL-NEON-SETUP.md
# URL da API da sua conta (Settings → Developer → API URL). Ex.: https://SUACONTA.api-us1.com
AC_API_URL=
# API Token (Settings → Developer → API Key).
AC_API_TOKEN=
# ID NUMÉRICO do custom field que guarda o link (GET /api/3/fields para descobrir).
AC_MAGIC_LINK_FIELD_ID=
# ID NUMÉRICO da tag que dispara a automação de onboarding (opcional). Aplicada
# ao contato DEPOIS de gravar o link — é o gatilho "tag adicionada" que envia o
# e-mail com %MAGIC_LINK%. Sem esta var, só o link é gravado (nenhuma tag).
# Descubra os IDs em GET /api/3/tags. Valor atual do piloto: 53414.
AC_ONBOARDING_TAG_ID=

# --- Frontend (Vite legado — até o cutover Next) ---
# Link de WhatsApp do CTA "pedir novo link".
VITE_SUPPORT_WA_URL=https://wa.me/5511999999999
# URL do Spot Form (embed para pesquisa de personalização).
VITE_SPOT_FORM_URL=

# --- Cloudinary (ingresso 8.3) ---
# Cloud name da conta Cloudinary (usado na URL de transformação e no upload).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# Upload preset NÃO ASSINADO por evento (foto do participante vai direto do cliente).
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
# public_id do template do ingresso (identidade do evento) usado no overlay.
NEXT_PUBLIC_CLOUDINARY_TICKET_TEMPLATE=
# public_id do avatar padrão (usado quando o participante não envia foto).
NEXT_PUBLIC_CLOUDINARY_TICKET_AVATAR=avatar-ingresso_suacwi

# --- Next.js (8.3) ---
# URL pública do app Next (montagem de magic link e do QR/shareUrl). Ex.: https://evento.exemplo.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Slug do evento ativo (usado pelo chat/form de ingresso ao chamar a API).
NEXT_PUBLIC_EVENT_SLUG=piloto
# Link do grupo de WhatsApp exibido ao final do fluxo do ingresso.
NEXT_PUBLIC_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/
