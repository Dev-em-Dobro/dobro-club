# Copie para `.env` (gitignored) e preencha. NUNCA coloque valores reais aqui.

# --- Server ---
# Segredo forte p/ assinar cookies de sessão. OBRIGATÓRIO em produção
# (o servidor recusa boot sem ele). Gere: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
DOBRO_SESSION_SECRET=
# URL pública usada para MONTAR os magic links (precisa bater com onde o app responde).
DOBRO_BASE_URL=http://localhost:3001
# "production" liga cookies Secure e o guard do segredo de sessão.
NODE_ENV=
# Hops de proxy confiáveis (IP correto no rate limit). 0 = sem proxy.
TRUST_PROXY_HOPS=0
PORT=3001

# --- Neon Postgres ---
# Connection string do painel da Neon (use o endpoint pooled "-pooler").
DATABASE_URL=
# Conexão direta (não-pooled), p/ migrations. Opcional.
DIRECT_URL=
# Neon root CA PEM; set to enforce TLS verification in prod (NEON_CA_CERT=<pem-contents>).
NEON_CA_CERT=

# --- Resend (entrega do magic link por e-mail) ---
# API key em resend.com.
RESEND_API_KEY=
# Remetente. PRECISA ser um e-mail de domínio verificado (ou onboarding@resend.dev p/ teste).
# Formato: "Nome <email@dominio>".
EMAIL_FROM=

# --- Frontend (Vite) ---
# Link de WhatsApp do CTA "pedir novo link".
VITE_SUPPORT_WA_URL=https://wa.me/5511999999999
