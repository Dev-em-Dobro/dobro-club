{
  "name": "dobro-club",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "dev:legacy": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "node server.js",
    "dev:web": "vite",
    "build:legacy": "vite build",
    "start:legacy": "npm run build:legacy && node server.js",
