    "db:configure-ac": "node scripts/configure-ac-event.js",
    "seed": "node scripts/seed.js",
    "link": "node scripts/magic-link.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "next": "^15",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.16.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.1",
    "jsdom": "^29.1.1",
    "pg-mem": "^3.0.14",
    "react-router-dom": "^7.18.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
